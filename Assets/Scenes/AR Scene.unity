  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "There are no carrots in this savory carrot cake\u2014at least not orange
    ones. Rather, the main components of the cake consist of rice flour and white
    radish, which some people refer to as white carrot. After steaming, the mixture
    is sliced into cubes and cooked with eggs, garlic, and \"chai poh,\" a pickled
    radish. Carrot cake is known as 'chai tow kway' in the Teochew language, these
    silky and fluffy fried rice cakes are available in nearly every hawker center.
    It comes either white (original) or black (fried with delicious dark soy sauce).
    The simple dish has its origins in Southern China\u2019s Chaoshan province. There,
    it is known as 'chao gao guo' (fried starch cake) which is made mainly with rice
    flour. Fish sauce and black sweetened soya sauce are used to marinate the rice
    cake before it is cut and fried with eggs, oysters and prawns."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
