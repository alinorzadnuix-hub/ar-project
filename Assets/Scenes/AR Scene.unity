  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Nasi lemak is one of the foods that is widely eaten in Singapore. Nasi
    lemak is a dish originating in Malay cuisine comprises coconut rice, a slice
    of omelet, anchovies, a slice of cucumber, and some chili paste, all packed in
    brown paper or banana leaf. It\u2019s mostly consumed as breakfast in both countries
    and commonly sold at hawker food centers and roadside stalls in Singapore."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
